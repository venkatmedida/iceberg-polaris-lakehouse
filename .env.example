# Copy this file to .env and fill in your values.
# .env is gitignored — never commit credentials.

# ── PostgreSQL (Polaris metastore) ───────────────────────────────
POSTGRES_PASSWORD=<choose-a-strong-password>

# ── Polaris root principal (bootstrap — admin use only) ──────────
POLARIS_ROOT_CLIENT_ID=polaris-root
POLARIS_ROOT_CLIENT_SECRET=<choose-a-strong-secret>

# ── Polaris service principal for Spark ──────────────────────────
# Auto-filled by setup/01_setup_polaris.py on first run
POLARIS_CLIENT_ID=
POLARIS_CLIENT_SECRET=

# ── Polaris catalog settings ─────────────────────────────────────
POLARIS_CATALOG_NAME=polaris_catalog
POLARIS_NAMESPACE=demo
POLARIS_URI=http://localhost:8181/api/catalog

# ── Azure — ADLS Gen2 ────────────────────────────────────────────
AZURE_TENANT_ID=<your-azure-tenant-id>
AZURE_STORAGE_ACCOUNT=<your-storage-account-name>
AZURE_CONTAINER=<your-container-name>

# Service principal used by Polaris for credential vending
# and by Spark for direct ADLS auth (fallback when vending unavailable).
# Requires: Storage Blob Data Contributor on the container.
AZURE_POLARIS_CLIENT_ID=<your-azure-sp-client-id>
AZURE_POLARIS_CLIENT_SECRET=<your-azure-sp-client-secret>
AZURE_SPARK_CLIENT_ID=<your-azure-sp-client-id>
AZURE_SPARK_CLIENT_SECRET=<your-azure-sp-client-secret>

# ── Snowflake ────────────────────────────────────────────────────
SNOWFLAKE_ACCOUNT=<orgname-accountname>.us-east-2.aws
SNOWFLAKE_USER=<your-snowflake-username>
SNOWFLAKE_PRIVATE_KEY_PATH=/path/to/snowflake_rsa_key.p8
SNOWFLAKE_WAREHOUSE=COMPUTE_WH
SNOWFLAKE_ROLE=ACCOUNTADMIN
# Public URL exposing local Polaris to Snowflake — run: ngrok http 8181
POLARIS_PUBLIC_HOST=https://<your-ngrok-subdomain>.ngrok-free.app
